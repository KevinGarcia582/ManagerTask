{
  "expo": {
    "name": "taskmanager-app",
    "slug": "taskmanager-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-owl.png",
    "scheme": "taskmanagerapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.uniboyaca.taskmanager",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.uniboyaca.taskmanager",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground-owl.png",
        "monochromeImage": "./assets/images/android-icon-monochrome-owl.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS"
      ],
      "notification": {
        "icon": "./assets/images/icon-owl.png",
        "color": "#003D66",
        "channelId": "default",
        "androidMode": "default",
        "androidCollapsedTitle": "ManagerTask"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon-owl.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-owl.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E6F4FE",
          "dark": {
            "backgroundColor": "#001A3A"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b5ac0906-4496-41fb-bb07-f63c7c2196eb"
      }
    },
    "owner": "andresplazas"
  }
}
